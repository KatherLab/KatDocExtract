# --- vLLM Backend Configuration ---
# Point this to your vLLM server hosting DeepSeek-VL-Chat or similar
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=deepseek-ai/DeepSeek-OCR

# --- Performance Tuning ---
# Max concurrent requests to vLLM. 
# Lower this if you hit GPU OOM or timeouts. Default is 100.
CONCURRENT_REQUEST_LIMIT=50

# --- File Storage ---
FILES_DIR=./files_store

# --- PDF Processing Heuristics ---
# If a page has less text coverage than this (0.01 = 1%), it is treated as an image.
MIN_TEXT_DENSITY=0.01
# If > 20% of the text layer contains replacement chars () or control codes, we ignore it and use OCR.
MAX_MOJIBAKE_RATIO=0.2
# DPI for rendering PDF pages to images (for OCR fallback or figure extraction)
PDF_TEXT_RENDER_DPI=150

# --- Output Format ---
# Add "---" separators between pages in the final markdown? (true/false)
MARKDOWN_PAGE_BREAKS=true
